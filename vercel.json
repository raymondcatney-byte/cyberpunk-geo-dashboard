{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/anomalies", "destination": "/api/search?action=anomalies" },
    { "source": "/api/hyperliquid/info", "destination": "/api/search?action=hyperliquid_info" }
  ],
  "crons": [
    {
      "path": "/api/intelligence/harvest",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/scan-flow",
      "schedule": "0 0 * * *"
    }
  ]
}
