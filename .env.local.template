# PM Flow Detection System - Environment Variables
# Copy this file to .env.local and fill in your actual values

# Upstash Redis (required for PM Flow Detection)
# Get these from https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Cron Secret (for securing the cron endpoint)
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-random-secret-key-here

# Optional: Public API URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
