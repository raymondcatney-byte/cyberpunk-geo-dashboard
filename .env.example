# NERV Dashboard Environment Variables

# Upstash Redis (for intelligence data persistence)
# Get these from https://console.upstash.com/ after creating a Redis database
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Upstash QStash (for scheduled harvest jobs)
# Get these from https://console.upstash.com/qstash
QSTASH_CURRENT_SIGNING_KEY=your_current_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# NewsAPI (for news intelligence feeds)
# Get from https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key

# Groq AI (for Bruce persona responses)
# Get from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key

# NASA FIRMS (optional - for thermal anomaly data)
# Get from https://firms.modaps.eosdis.nasa.gov/
FIRMS_API_KEY=your_firms_api_key
